<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>一维势垒隧穿 · 双图：概率密度 & 波函数实部（实部自适应缩放，势垒区全纵轴）</title>
    <style>
        * { box-sizing: border-box; font-family: 'Segoe UI', Roboto, sans-serif; }
        body { background: #eef2f6; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 20px; }
        .card { max-width: 1400px; width: 100%; background: rgba(255,255,255,0.9); border-radius: 40px; box-shadow: 0 20px 40px rgba(0,10,20,0.2); padding: 25px 30px; }
        h1 { font-size: 1.9rem; color: #1e2b3c; }
        .const-bar { background: #1e2b3c; color: #bcd3f0; padding: 12px 20px; border-radius: 60px; margin: 15px 0 25px; display: flex; flex-wrap: wrap; gap: 25px; }
        .panel { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap: 20px; margin-bottom: 30px; }
        .slider-group { background: #f8fafd; border-radius: 36px; padding: 18px 22px; box-shadow: inset 0 2px 5px #cdd9e9; }
        .slider-group label { display: flex; justify-content: space-between; font-weight: 600; color: #0f2b3f; margin-bottom: 12px; }
        .slider-group label span { background: #1e3b4f; color: white; padding: 4px 16px; border-radius: 50px; font-size: 0.95rem; }
        input[type=range] { width: 100%; height: 10px; background: linear-gradient(90deg, #3c6e8f, #a3c6e9); border-radius: 20px; -webkit-appearance: none; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 24px; height: 24px; background: white; border-radius: 50%; border: 2px solid #1e506a; cursor: pointer; }
        .value-badge { font-size: 1.2rem; font-weight: 600; color: #003153; text-align: center; margin-top: 12px; }
        .transmit-card, .reflect-card { background: #dceaf5; border-radius: 40px; padding: 15px 25px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px; }
        .transmit-value, .reflect-value { font-family: monospace; font-size: 2rem; font-weight: 700; background: #011b2b; color: #9fd9ff; padding: 8px 30px; border-radius: 60px; }
        .reflect-card { background: #e3d9cf; }
        .reflect-value { color: #ffdba5; }
        .charts-container { display: flex; gap: 20px; margin-top: 20px; }
        .chart-box { flex: 1; background: #f0f4fc; border-radius: 30px; padding: 15px; box-shadow: inset 0 0 0 1px white, 0 12px 24px rgba(0,20,40,0.2); }
        canvas { width: 100%; height: auto; border-radius: 20px; background: white; }
        .footnote { margin-top: 20px; color: #2b4b65; font-size: 0.9rem; display: flex; gap: 30px; flex-wrap: wrap; justify-content: center; }
        .barrier-mark { background: rgba(128,128,128,0.25); padding: 2px 8px; border-radius: 12px; }
        .legend-sample { display: inline-block; width: 20px; height: 3px; margin-right: 5px; vertical-align: middle; }
        .chart-title { text-align: center; font-weight: 600; margin-bottom: 10px; color: #1e3a5f; }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1/dist/chartjs-plugin-annotation.min.js"></script>
</head>
<body>
<div class="card">
    <h1>⚛️ 一维方势垒 · 量子隧穿 <small>双图：概率密度 (左) 与 波函数实部 (右)</small></h1>
    <div class="const-bar">
        <span><strong>ħ</strong> = 1.0545718×10⁻³⁴ J·s</span>
        <span><strong>mₑ</strong> = 9.1093837×10⁻³¹ kg</span>
        <span><strong>1 eV</strong> = 1.60217662×10⁻¹⁹ J</span>
    </div>

    <div class="panel">
        <div class="slider-group">
            <label>🧪 粒子质量 <span id="massValue">1.00 mₑ</span></label>
            <input type="range" id="massSlider" min="0.1" max="10" value="1.0" step="0.01">
            <div class="value-badge" id="massAbs">9.11×10⁻³¹ kg</div>
        </div>
        <div class="slider-group">
            <label>📏 势垒宽度 <span id="widthValue">0.10 nm</span></label>
            <input type="range" id="widthSlider" min="0.1" max="5.0" value="0.1" step="0.01">
            <div class="value-badge" id="widthAbs">0.10 nm</div>
        </div>
        <div class="slider-group">
            <label>⛰️ 势垒高度 V₀ <span id="V0Value">5.00 eV</span></label>
            <input type="range" id="V0Slider" min="0.2" max="5.0" value="5.0" step="0.01">
            <div class="value-badge" id="V0Abs">5.00 eV</div>
        </div>
        <div class="slider-group">
            <label>⚡ 入射能量 E <span id="EValue">2.00 eV</span></label>
            <input type="range" id="ESlider" min="0.05" max="2.8" value="2.0" step="0.01">
            <div class="value-badge" id="EAbs">2.00 eV</div>
        </div>
    </div>

    <div class="transmit-card">
        <span class="transmit-label">🔁 透射系数 T = |t|²</span>
        <span class="transmit-value" id="TDisplay">0.000000</span>
    </div>
    <div class="reflect-card">
        <span class="reflect-label">🔂 反射系数 R = |r|²</span>
        <span class="reflect-value" id="RDisplay">0.000000</span>
    </div>

    <div class="charts-container">
        <!-- 左图：概率密度 -->
        <div class="chart-box">
            <div class="chart-title">概率密度 |ψ|²</div>
            <canvas id="probChart" width="400" height="300"></canvas>
        </div>
        <!-- 右图：波函数实部 -->
        <div class="chart-box">
            <div class="chart-title">波函数实部 Re(ψ)</div>
            <canvas id="realChart" width="400" height="300"></canvas>
        </div>
    </div>

    <div class="footnote">
        <span><span class="legend-sample" style="background:#c5283d;"></span> 概率密度 (左轴)</span>
        <span><span class="legend-sample" style="background:#1e6f9f;"></span> 实部 (右轴)</span>
        <span>▪ 区域 II <span class="barrier-mark">灰色背景</span> 势垒区 (覆盖全纵轴)</span>
        <span>▪ 鼠标悬停显示数值</span>
        <span>▪ 实部纵轴已自适应缩放</span>
    </div>
</div>

<script>
(function() {
    // 物理常数
    const me = 9.1093837e-31;          // kg
    const hbar = 1.0545718e-34;        // J·s
    const eV = 1.60217662e-19;         // J
    const nm = 1e-9;                   // m

    // DOM 元素
    const massSlider = document.getElementById('massSlider');
    const widthSlider = document.getElementById('widthSlider');
    const V0Slider = document.getElementById('V0Slider');
    const ESlider = document.getElementById('ESlider');
    const massSpan = document.getElementById('massValue');
    const widthSpan = document.getElementById('widthValue');
    const V0Span = document.getElementById('V0Value');
    const ESpan = document.getElementById('EValue');
    const massAbs = document.getElementById('massAbs');
    const widthAbs = document.getElementById('widthAbs');
    const V0Abs = document.getElementById('V0Abs');
    const EAbs = document.getElementById('EAbs');
    const TDisplay = document.getElementById('TDisplay');
    const RDisplay = document.getElementById('RDisplay');

    // 注册 Annotation 插件
    try {
        Chart.register(ChartAnnotation);
        console.log('Annotation 插件注册成功');
    } catch (e) {
        console.error('Annotation 插件注册失败:', e);
    }

    // 创建两个图表的通用配置 (带灰色背景注释，覆盖全纵轴)
    function createChartConfig(yAxisTitle, yAxisColor, datasetColor, initialData, isProbability = true) {
        return {
            type: 'line',
            data: {
                datasets: [{
                    label: isProbability ? '概率密度' : '实部',
                    data: initialData,
                    borderColor: datasetColor,
                    backgroundColor: isProbability ? 'rgba(197,40,61,0.08)' : 'transparent',
                    tension: 0.4,
                    pointRadius: 0,
                    borderWidth: isProbability ? 3 : 2,
                    fill: isProbability,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                animation: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        enabled: true,
                        callbacks: {
                            label: function(context) {
                                return context.raw.y.toFixed(4);
                            }
                        }
                    },
                    annotation: {
                        annotations: {
                            barrier: {
                                type: 'box',
                                xMin: 0,
                                xMax: 0.1,   // 初始值，稍后更新
                                yMin: 'min',  // 覆盖纵轴最小值
                                yMax: 'max',  // 覆盖纵轴最大值
                                backgroundColor: 'rgba(128, 128, 128, 0.25)',
                                borderWidth: 0,
                                drawTime: 'beforeDatasetsDraw',
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        type: 'linear',
                        title: { display: true, text: '位置 x (nm)', color: '#1f3a4c' },
                        grid: { color: '#cbdae6' },
                    },
                    y: {
                        title: { display: true, text: yAxisTitle, color: yAxisColor },
                        grid: { color: '#cbdae6' },
                        // 概率密度图 min 固定为0，max动态；实部图 min/max 将在更新时动态设置
                    }
                }
            }
        };
    }

    // 初始化两个图表
    const ctxProb = document.getElementById('probChart').getContext('2d');
    const ctxReal = document.getElementById('realChart').getContext('2d');

    let probChart = new Chart(ctxProb, createChartConfig('概率密度', '#c5283d', '#c5283d', [], true));
    let realChart = new Chart(ctxReal, createChartConfig('实部 Re(ψ)', '#1e6f9f', '#1e6f9f', [], false));

    // 科学计数法显示
    function toScientific(x, digits = 2) {
        if (x === 0) return '0';
        let exp = Math.floor(Math.log10(Math.abs(x)));
        let mant = x / Math.pow(10, exp);
        return mant.toFixed(digits) + '×10<sup>' + exp + '</sup>';
    }

    // 更新滑块标签
    function updateLabels() {
        let mFact = parseFloat(massSlider.value);
        let w = parseFloat(widthSlider.value);
        let v0 = parseFloat(V0Slider.value);
        let e = parseFloat(ESlider.value);

        massSpan.innerText = mFact.toFixed(2) + ' mₑ';
        widthSpan.innerText = w.toFixed(2) + ' nm';
        V0Span.innerText = v0.toFixed(2) + ' eV';
        ESpan.innerText = e.toFixed(2) + ' eV';

        let m_kg = mFact * me;
        massAbs.innerHTML = toScientific(m_kg, 2) + ' kg';
        widthAbs.innerText = w.toFixed(2) + ' nm';
        V0Abs.innerText = v0.toFixed(2) + ' eV';
        EAbs.innerText = e.toFixed(2) + ' eV';
    }

    // 核心计算与绘图
    function refreshPlot() {
        try {
            updateLabels();

            let m_fact = parseFloat(massSlider.value);
            let a_nm = parseFloat(widthSlider.value);
            let V0_eV = parseFloat(V0Slider.value);
            let E_eV = parseFloat(ESlider.value);

            // 避免 E 与 V0 过于接近
            if (Math.abs(E_eV - V0_eV) < 1e-6) {
                E_eV = V0_eV + 1e-5;
            }

            let m = m_fact * me;
            let a = a_nm * nm;
            let V0 = V0_eV * eV;
            let E = E_eV * eV;

            // 波矢 k1 (nm^{-1})
            let k1 = Math.sqrt(2 * m * Math.abs(E)) / hbar;
            let k1_nm = k1 * nm;

            // 能量判断
            let epsilon = 1e-20;
            let isBelow = (E < V0 - epsilon);
            let isAbove = (E > V0 + epsilon);

            let k2_nm = 0, kappa_nm = 0;
            if (isBelow) {
                kappa_nm = Math.sqrt(2 * m * (V0 - E)) / hbar * nm;
            } else {
                k2_nm = Math.sqrt(2 * m * Math.abs(E - V0)) / hbar * nm;
            }

            // 计算透射和反射系数
            let t_re = 0, t_im = 0, r_re = 0, r_im = 0;
            let T = 0, R = 0;

            if (isAbove) {
                let θ = k2_nm * a_nm;
                let sinθ = Math.sin(θ);
                let cosθ = Math.cos(θ);
                let k1_ = k1_nm;
                let k2_ = k2_nm;

                let denom_re = 2 * k1_ * k2_ * cosθ;
                let denom_im = -(k1_*k1_ + k2_*k2_) * sinθ;
                let denom2 = denom_re*denom_re + denom_im*denom_im;
                if (denom2 > 1e-30) {
                    let numerator = 2 * k1_ * k2_;
                    t_re = numerator * denom_re / denom2;
                    t_im = - numerator * denom_im / denom2;
                }
                T = t_re*t_re + t_im*t_im;

                let r_num = (k1_*k1_ - k2_*k2_) * sinθ;
                let r_denom_re = (k1_*k1_ + k2_*k2_) * sinθ;
                let r_denom_im = 2 * k1_ * k2_ * cosθ;
                let r_denom2 = r_denom_re*r_denom_re + r_denom_im*r_denom_im;
                if (r_denom2 > 1e-30) {
                    r_re = r_num * r_denom_re / r_denom2;
                    r_im = - r_num * r_denom_im / r_denom2;
                }
                R = r_re*r_re + r_im*r_im;
            } else if (isBelow) {
                let κ = kappa_nm;
                let θ = κ * a_nm;
                let sinhθ = Math.sinh(θ);
                let coshθ = Math.cosh(θ);
                let k1_ = k1_nm;

                let denom_re = (k1_*k1_ - κ*κ) * sinhθ;
                let denom_im = 2 * k1_ * κ * coshθ;
                let denom2 = denom_re*denom_re + denom_im*denom_im;
                if (denom2 > 1e-30) {
                    let numer_im = 2 * k1_ * κ;
                    t_re = numer_im * denom_im / denom2;
                    t_im = numer_im * denom_re / denom2;
                }
                T = t_re*t_re + t_im*t_im;

                let r_num_im = (k1_*k1_ + κ*κ) * sinhθ;
                let r_denom_re = -2 * k1_ * κ * coshθ;
                let r_denom_im = (k1_*k1_ - κ*κ) * sinhθ;
                let r_denom2 = r_denom_re*r_denom_re + r_denom_im*r_denom_im;
                if (r_denom2 > 1e-30) {
                    r_re = r_num_im * r_denom_im / r_denom2;
                    r_im = r_num_im * r_denom_re / r_denom2;
                }
                R = r_re*r_re + r_im*r_im;
            } else {
                T = 0;
                R = 1;
            }

            T = Math.min(T, 0.999999);
            R = Math.min(R, 0.999999);
            TDisplay.innerText = T.toFixed(6);
            RDisplay.innerText = R.toFixed(6);

            // 更新两个图表的势垒灰色区域 (只更新 xMax，yMin/yMax 使用 'min'/'max' 自动适应)
            if (probChart.options.plugins?.annotation?.annotations) {
                probChart.options.plugins.annotation.annotations.barrier.xMax = a_nm;
            }
            if (realChart.options.plugins?.annotation?.annotations) {
                realChart.options.plugins.annotation.annotations.barrier.xMax = a_nm;
            }

            // 计算概率密度和实部曲线
            let x_min = -2.0;
            let x_max = a_nm + 2.0;
            let steps = 600;
            let points_prob = [];
            let points_real = [];
            let dx = (x_max - x_min) / steps;

            // 计算区域 II 系数 A, B
            let A_re = 0, A_im = 0, B_re = 0, B_im = 0;

            if (isAbove) {
                let k1_ = k1_nm;
                let k2_ = k2_nm;
                let onePr_re = 1 + r_re;
                let onePr_im = r_im;
                let oneMr_re = 1 - r_re;
                let oneMr_im = -r_im;

                let factor = k1_ / k2_;
                let termA_re = factor * oneMr_re;
                let termA_im = factor * oneMr_im;

                A_re = 0.5 * (onePr_re + termA_re);
                A_im = 0.5 * (onePr_im + termA_im);
                B_re = 0.5 * (onePr_re - termA_re);
                B_im = 0.5 * (onePr_im - termA_im);
            } else if (isBelow) {
                let κ = kappa_nm;
                let k1_ = k1_nm;
                let onePr_re = 1 + r_re;
                let onePr_im = r_im;
                let oneMr_re = 1 - r_re;
                let oneMr_im = -r_im;

                let factor = k1_ / κ;
                // A - B = -i * factor * (1 - r)
                let AminusB_re = factor * oneMr_im;
                let AminusB_im = -factor * oneMr_re;

                A_re = 0.5 * (onePr_re + AminusB_re);
                A_im = 0.5 * (onePr_im + AminusB_im);
                B_re = 0.5 * (onePr_re - AminusB_re);
                B_im = 0.5 * (onePr_im - AminusB_im);
            }

            // 遍历 x
            for (let i = 0; i <= steps; i++) {
                let x = x_min + i * dx;
                let prob = 0;
                let real = 0;

                if (x < 0) {
                    // 区域 I: ψ = e^{ikx} + r e^{-ikx}
                    let kx = k1_nm * x;
                    let ei_re = Math.cos(kx);
                    let ei_im = Math.sin(kx);
                    let e_minus_re = Math.cos(kx);      // cos(-kx)=cos(kx)
                    let e_minus_im = -Math.sin(kx);     // sin(-kx) = -sin(kx)
                    // r * e^{-ikx}
                    let r_e_re = r_re * e_minus_re - r_im * e_minus_im;
                    let r_e_im = r_re * e_minus_im + r_im * e_minus_re;
                    let psi_re = ei_re + r_e_re;
                    let psi_im = ei_im + r_e_im;
                    prob = psi_re*psi_re + psi_im*psi_im;
                    real = psi_re;
                } else if (x >= 0 && x <= a_nm) {
                    // 区域 II
                    if (isAbove) {
                        let k2x = k2_nm * x;
                        let eik2_re = Math.cos(k2x);
                        let eik2_im = Math.sin(k2x);
                        let eik2_minus_re = Math.cos(k2x);
                        let eik2_minus_im = -Math.sin(k2x);

                        let A_e_re = A_re * eik2_re - A_im * eik2_im;
                        let A_e_im = A_re * eik2_im + A_im * eik2_re;
                        let B_e_re = B_re * eik2_minus_re - B_im * eik2_minus_im;
                        let B_e_im = B_re * eik2_minus_im + B_im * eik2_minus_re;

                        let psi_re = A_e_re + B_e_re;
                        let psi_im = A_e_im + B_e_im;
                        prob = psi_re*psi_re + psi_im*psi_im;
                        real = psi_re;
                    } else if (isBelow) {
                        let exp_neg = Math.exp(-kappa_nm * x);
                        let exp_pos = Math.exp(kappa_nm * x);
                        let A_e_re = A_re * exp_neg;
                        let A_e_im = A_im * exp_neg;
                        let B_e_re = B_re * exp_pos;
                        let B_e_im = B_im * exp_pos;
                        let psi_re = A_e_re + B_e_re;
                        let psi_im = A_e_im + B_e_im;
                        prob = psi_re*psi_re + psi_im*psi_im;
                        real = psi_re;
                    } else {
                        prob = 0;
                        real = 0;
                    }
                } else {
                    // 区域 III: ψ = t e^{i k1 (x - a)}
                    let xshift = x - a_nm;
                    let phase = k1_nm * xshift;
                    let eik_re = Math.cos(phase);
                    let eik_im = Math.sin(phase);
                    let psi_re = t_re * eik_re - t_im * eik_im;
                    let psi_im = t_re * eik_im + t_im * eik_re;
                    prob = psi_re*psi_re + psi_im*psi_im;
                    real = psi_re;
                }

                if (prob < 0) prob = 0;
                points_prob.push({ x: x, y: prob });
                points_real.push({ x: x, y: real });
            }

            // 计算概率密度最大值，动态设置左轴上限
            let maxProb = Math.max(...points_prob.map(p => p.y));
            let yMaxProb = Math.max(1, maxProb * 1.2);
            probChart.options.scales.y.max = yMaxProb;

            // 计算实部绝对值的最大值，设置对称 y 轴范围
            let maxAbsReal = Math.max(...points_real.map(p => Math.abs(p.y)));
            // 如果最大绝对值很小（例如小于 1e-6），则设置为默认范围 [-1,1] 避免全零图
            if (maxAbsReal < 1e-12) maxAbsReal = 1.0; // 若实部全零，展示 [-1,1] 范围
            let yMaxReal = maxAbsReal * 1.2;
            realChart.options.scales.y.min = -yMaxReal;
            realChart.options.scales.y.max = yMaxReal;

            // 更新两个图表的数据
            probChart.data.datasets[0].data = points_prob;
            realChart.data.datasets[0].data = points_real;

            // 更新 x 轴范围
            probChart.options.scales.x.min = x_min;
            probChart.options.scales.x.max = x_max;
            realChart.options.scales.x.min = x_min;
            realChart.options.scales.x.max = x_max;

            // 更新图表
            probChart.update();
            realChart.update();
        } catch (err) {
            console.error('refreshPlot 错误:', err);
        }
    }

    // 绑定事件
    [massSlider, widthSlider, V0Slider, ESlider].forEach(slider => {
        slider.addEventListener('input', refreshPlot);
    });

    // 初始调用
    refreshPlot();
})();
</script>
</body>
</html>
